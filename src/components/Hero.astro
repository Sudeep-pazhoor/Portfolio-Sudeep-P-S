---
import { portfolioData } from '../data/portfolio';
---
<section id="home" class="hero">
  <div class="container">
    <p class="text-muted text-h3 tag">Hello, I am {portfolioData.name}</p>
    <h1 class="text-title title mt-md">
      {portfolioData.role}.<br />
      <span class="text-muted">crafting web experiences.</span>
    </h1>
    <div class="resume-actions resume-anim mt-lg">
      <a href="/Sudeep P S Resume.pdf" target="_blank" class="btn btn-primary" rel="noopener noreferrer">View Resume</a>
      <a href="/Sudeep P S Resume.pdf" download="Sudeep_P_S_Resume.pdf" class="btn btn-outline">Download Resume</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    width: 100%;
  }
  .title {
    opacity: 0;
  }
  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
    }
  }
  .resume-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  @media (max-width: 600px) {
    .resume-actions {
      flex-direction: column;
      width: 100%;
    }
    .btn {
      width: 100%;
    }
  }
  .resume-anim {
    opacity: 0;
    transform: translateY(20px);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 5px;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .btn-primary {
    background-color: var(--text-color);
    color: var(--bg-color);
    border: 1px solid var(--text-color);
  }
  .btn-primary:hover {
    background-color: transparent;
    color: var(--text-color);
    opacity: 1;
  }
  .btn-outline {
    background-color: transparent;
    color: var(--text-color);
    border: 1px solid var(--text-color);
  }
  .btn-outline:hover {
    background-color: var(--text-color);
    color: var(--bg-color);
    opacity: 1;
  }
</style>

<script>
  import gsap from 'gsap';
  
  // Minimal load animation
  gsap.to('.tag', { y: 0, opacity: 1, duration: 1, delay: 0.2, ease: 'power3.out' });
  gsap.to('.title', { y: 0, opacity: 1, duration: 1, delay: 0.4, ease: 'power3.out' });
  gsap.to('.resume-anim', { y: 0, opacity: 1, duration: 1, delay: 0.6, ease: 'power3.out' });
</script>
