---
// Navigation Component
import { portfolioData } from '../data/portfolio';

const navLinks = [
  { name: 'About', href: '/#about' },
  { name: 'Experience', href: '/#experience' },
  { name: 'Work', href: '/works' },
  { name: 'Contact', href: '/contact' }
];

const socialLinks = [
  {
    name: 'GitHub',
    href: portfolioData.github,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>`
  },
  {
    name: 'LinkedIn',
    href: portfolioData.linkedin,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>`
  },
  {
    name: 'Email',
    href: `mailto:${portfolioData.email}`,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>`
  }
];
---
<nav class="navigation">
  <div class="logo-container">
    <a href="/#home" class="logo">Sudeep / Web</a>
  </div>

  <div class="desktop-links">
    {navLinks.map(link => (
      <a href={link.href} class="nav-link">{link.name}</a>
    ))}
    <div class="desktop-divider"></div>
    {socialLinks.map(link => (
      <a href={link.href} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={link.name} set:html={link.icon} />
    ))}
    <div class="desktop-divider"></div>
    <button id="theme-toggle-desktop" class="theme-icon-btn" aria-label="Toggle theme">
      <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg class="sun-icon hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
    </button>
  </div>

  <div class="menu-wrapper">
    <button class="menu-toggle" aria-label="Toggle Menu">
      <span class="menu-text">Menu</span>
      <div class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </button>
    
    <div class="menu-content">
      <div class="menu-links">
        {navLinks.map(link => (
          <a href={link.href} class="menu-link">{link.name}</a>
        ))}
        <div class="menu-divider"></div>
        <div class="menu-socials">
          <span class="theme-label" style="padding: 0.6rem 1rem; font-size: 0.85rem; opacity: 0.7;">Socials</span>
          <div class="social-icons-wrapper">
            {socialLinks.map(link => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="social-icon-btn-mobile" aria-label={link.name} set:html={link.icon} />
            ))}
          </div>
        </div>
        <div class="menu-divider"></div>
        <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
          <span class="theme-label">Theme</span>
          <div class="theme-icons">
            <svg id="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <svg id="theme-icon-sun" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </div>
        </button>
      </div>
    </div>
  </div>
</nav>

<style>
  .navigation {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: var(--spacing-md) 5vw;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1000;
    pointer-events: none;
  }

  .logo-container {
    pointer-events: auto;
  }

  .logo {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--text-color);
    mix-blend-mode: difference;
    filter: invert(1);
    transition: color 0.3s ease;
  }

  /* Keep logo visible on dark backgrounds */
  :global([data-theme="dark"]) .logo {
    filter: invert(0);
  }

  .desktop-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    pointer-events: auto;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-color);
    transition: opacity 0.3s ease;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
  }

  .nav-link:hover {
    background: var(--card-bg);
    opacity: 0.8;
  }

  .desktop-divider {
    width: 1px;
    height: 1.5rem;
    background: var(--border-color);
    margin: 0 0.5rem;
  }

  .social-icon-btn, .theme-icon-btn {
    background: none;
    border: none;
    color: var(--text-color);
    cursor: pointer;
    display: flex;
    align-items: center;
    padding: 0.4rem;
    border-radius: 50%;
    transition: background 0.3s ease, transform 0.2s ease;
  }

  .social-icon-btn:hover, .theme-icon-btn:hover {
    background: var(--card-bg);
    transform: translateY(-2px);
  }

  .menu-wrapper {
    position: relative;
    pointer-events: auto;
  }

  .menu-toggle {
    background: var(--text-color);
    color: var(--bg-color);
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    cursor: pointer;
    font-family: inherit;
    font-weight: 500;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .menu-toggle:hover {
    transform: scale(1.05);
  }

  .hamburger {
    width: 18px;
    height: 12px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: currentColor;
    transition: all 0.3s ease;
    border-radius: 1px;
  }

  /* Hamburger Animation */
  .menu-wrapper.active .hamburger span:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  .menu-wrapper.active .hamburger span:nth-child(2) {
    opacity: 0;
  }
  .menu-wrapper.active .hamburger span:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }

  .menu-content {
    position: absolute;
    top: calc(100% + 1rem);
    right: 0;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    padding: 0.8rem;
    min-width: 220px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px) scale(0.95);
    transform-origin: top right;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .menu-wrapper:hover .menu-content,
  .menu-wrapper.active .menu-content {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .menu-links {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .menu-link {
    padding: 0.6rem 1rem;
    border-radius: 6px;
    transition: background 0.2s ease;
    font-size: 0.95rem;
    display: block;
  }

  .menu-link:hover {
    background: var(--card-bg);
  }

  .menu-divider {
    height: 1px;
    background: var(--border-color);
    margin: 0.4rem 0.5rem;
  }

  .menu-socials {
    display: flex;
    flex-direction: column;
  }
  
  .social-icons-wrapper {
    display: flex;
    gap: 0.5rem;
    padding: 0 1rem 0.5rem 1rem;
  }

  .social-icon-btn-mobile {
    color: var(--text-color);
    padding: 0.4rem;
    border-radius: 50%;
    transition: background 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .social-icon-btn-mobile:hover {
    background: var(--card-bg);
  }

  .theme-btn {
    background: transparent;
    border: none;
    color: inherit;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 1rem;
    border-radius: 6px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s ease;
  }

  .theme-btn:hover {
    background: var(--card-bg);
  }

  .hidden {
    display: none;
  }

  @media (max-width: 768px) {
    .navigation {
      top: 0;
      bottom: auto; /* Ensure navigation is at top on mobile as requested by "hamburger button for mobile device view" */
      padding: 1rem 5vw;
      background: var(--bg-color); /* Added solid background for mobile header */
      border-bottom: 1px solid var(--border-color); /* Separator line on scroll, can adjust later if needed */
    }
    .desktop-links {
      display: none;
    }
    .menu-content {
      top: calc(100% + 0.5rem);
      bottom: auto;
    }
    .logo-container {
      position: static;
    }
    /* Menu works better without hover trick on touch devices, so relying on click */
    .menu-wrapper:hover .menu-content {
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px) scale(0.95);
    }
    .menu-wrapper.active .menu-content {
      opacity: 1;
      visibility: visible;
      transform: translateY(0) scale(1);
    }
  }

  @media (min-width: 769px) {
    .menu-wrapper {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const menuWrapper = document.querySelector('.menu-wrapper');
  const toggle = document.querySelector('.menu-toggle');
  const themeToggles = document.querySelectorAll('#theme-toggle, #theme-toggle-desktop');

  // Toggle for Mobile (Click)
  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    menuWrapper?.classList.toggle('active');
  });

  document.addEventListener('click', () => {
    menuWrapper?.classList.remove('active');
  });

  menuWrapper?.addEventListener('click', (e) => {
    e.stopPropagation(); // Prevent closing menu when clicking inside
  });

  // Theme Toggle logic
  const handleThemeToggle = () => {
    const theme = document.documentElement.getAttribute('data-theme');
    const newTheme = theme === 'dark' ? 'light' : 'dark';
    
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
    updateIcon(newTheme);
  };

  /** @param {string} theme */
  const updateIcon = (theme: string) => {
    const moons = document.querySelectorAll('#theme-icon-moon, .moon-icon');
    const suns = document.querySelectorAll('#theme-icon-sun, .sun-icon');
    
    if (theme === 'dark') {
      moons.forEach(m => m.classList.add('hidden'));
      suns.forEach(s => s.classList.remove('hidden'));
    } else {
      moons.forEach(m => m.classList.remove('hidden'));
      suns.forEach(s => s.classList.add('hidden'));
    }
  };

  // Init theme icon
  const currentTheme = () => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme') || 'light';
    }
    return 'light';
  };
  updateIcon(currentTheme());

  themeToggles.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      handleThemeToggle();
    });
  });
</script>
